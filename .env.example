# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=batmonai
POSTGRES_USER=batmonai
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-side port mapping (change to avoid conflicts with other local projects)
POSTGRES_HOST_PORT=5450

# ── App DB user (non-superuser — subject to RLS; used by API + ingestion) ─────
# POSTGRES_USER is the DB superuser used ONLY for migrations.
# APP_DB_USER is a non-superuser role created by the migrate entrypoint.
APP_DB_USER=batmonai_app
APP_DB_PASSWORD=changeme_app_db_password

# ── PgBouncer ─────────────────────────────────────────────────────────────────
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
PGBOUNCER_HOST_PORT=6450
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=20

# ── Mosquitto MQTT ────────────────────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT_TLS=8883
MQTT_PORT_PLAIN=1883
# Host-side port mappings
MQTT_HOST_PORT_TLS=8883
MQTT_HOST_PORT_PLAIN=1884

# Ingestion service MQTT credentials (written to mosquitto passwd file by entrypoint)
MQTT_INGESTION_PASSWORD=changeme_mqtt_ingestion_password

# Optional: test device for sim_publisher TLS mode (comment out if not needed)
# MQTT_TEST_DEVICE_UID=test-appliance-001
# MQTT_TEST_DEVICE_PASSWORD=changeme_test_device_password

# Set true only if TLS cert hostname does not match (should not be needed with SANs)
MQTT_TLS_INSECURE=false

# ── API (FastAPI) ─────────────────────────────────────────────────────────────
API_HOST_PORT=8010
API_WORKERS=1
API_LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_HOST_PORT=5180

# ── Caddy (dev) ───────────────────────────────────────────────────────────────
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme_jwt_secret_at_least_32_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Superuser (seeded on first boot, never in migrations) ─────────────────────
SUPERUSER_EMAIL=admin@batmon.local
SUPERUSER_PASSWORD=changeme_superuser_password

# ── SMTP (for client welcome emails & alerts) ─────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=changeme_smtp_password
SMTP_FROM=alerts@batmon.local
SMTP_TLS=true

# ── Telemetry publish interval ────────────────────────────────────────────────
PUBLISH_INTERVAL_SECONDS=10

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Device-offline threshold = OFFLINE_MULTIPLIER * PUBLISH_INTERVAL_SECONDS
OFFLINE_MULTIPLIER=3

# ── Firmware / RS485 Modbus slave IDs ────────────────────────────────────────
# These values MUST match config.h in the firmware (firmware/include/config.h).
# They are also stored in the DB (batteries.modbus_addr / ac_channels.modbus_addr).
INVERTER_SLAVE_ID=1
BATTERY1_SLAVE_ID=2
BATTERY2_SLAVE_ID=3
TEMPERATURE_SLAVE_ID=4
HYDROGEN_SLAVE_ID=5
# Future sensors: add NEWSENSOR_SLAVE_ID=N here and mirror in config.h
