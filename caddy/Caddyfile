# batmonai Caddyfile — dev
# Serves on localhost with auto-TLS (mkcert / self-signed).
# Override in docker-compose.prod.yml with Caddyfile.prod.

{
    # Local CA for dev (generated by mkcert or Caddy's built-in ACME)
    local_certs
    log {
        level INFO
    }
}

localhost {
    # Frontend
    handle /* {
        reverse_proxy frontend:80
    }

    # API
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8000
    }
}
