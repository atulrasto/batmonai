# batmonai Mosquitto ACL
#
# Pattern: each device (appliance_uid) may only publish/subscribe to its own topic.
# The ingestion service uses a dedicated superuser account.
#
# Format:
#   user <username>
#   topic [read|write|readwrite] <topic>
#
# %u is substituted with the connecting username.

# Ingestion service — full read access to all telemetry topics
user ingestion
topic read batmon/#
topic read $SYS/#

# Per-device pattern — each appliance_uid can only touch its own topics
# This is the template; actual entries are generated by the provisioning step.
# pattern publish batmon/%u/#
# pattern subscribe batmon/%u/cmd

# Wildcard pattern rule (applies to all authenticated users not listed above)
pattern write batmon/%u/telemetry
pattern write batmon/%u/status
pattern read batmon/%u/cmd
